# ──────────────────────────────────
# CA1B Connect - Environment Variables
# ──────────────────────────────────

# 🔥 FIREBASE CONFIG (Frontend - Vite)
# These are needed at build time. Vite exposes them via import.meta.env.VITE_*
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# 🤖 GEMINI AI (Backend - Firebase Functions)
# Used in functions/ directory, loaded via process.env.GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here

# 📚 GOOGLE CLASSROOM (Backend - Vercel API Routes)
# Used in api/classroom/ directory, loaded via process.env.GOOGLE_CLASSROOM_*
# These come from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLASSROOM_CLIENT_ID=812083670104-227kjnu395dpahm2e117qgq0q5s22vas.apps.googleusercontent.com
GOOGLE_CLASSROOM_CLIENT_SECRET=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

# 🔗 VERCEL DEPLOYED URL (Frontend + Backend)
# Used by the classroom oauth-init API route to auto-detect the callback URL
# Set this in Vercel dashboard: Settings > Environment Variables
VITE_API_BASE_URL = https://ca1b-connect.vercel.app
